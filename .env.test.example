IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASS=change-me

# Uzywaj tylko folderow testowych, nie produkcyjnego AI-Review.
IMAP_SOURCE_FOLDER=INBOX.Test-AI-Review
IMAP_UNCERTAIN_FOLDER=INBOX.Test-AI-Uncertain
IMAP_APPOINTMENTS_FOLDER=INBOX.Test-Appointments
IMAP_QUESTIONS_FOLDER=INBOX.Test-Questions
IMAP_COMPLAINTS_FOLDER=INBOX.Test-Complaints
IMAP_SPAM_FOLDER=INBOX.Test-Junk
IMAP_NEWSLETTER_FOLDER=INBOX.Test-Newsletter
IMAP_OFFER_FOLDER=INBOX.Test-Offer
IMAP_OTHER_FOLDER=INBOX.Test-Other
IMAP_BILLING_FOLDER=INBOX.Test-Billing
IMAP_SYSTEM_FOLDER=INBOX.Test-System

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_TEMPERATURE=0.1

MOVE_CONFIDENCE_THRESHOLD=0.75
OTHER_MOVE_CONFIDENCE_THRESHOLD=0.50
FLAG_CONFIDENCE_THRESHOLD=0.80
DRAFT_CONFIDENCE_THRESHOLD=0.85
PROCESSING_LEASE_SECONDS=900
MAX_BODY_CHARS=12000
MAX_RETRIES=3
LOG_LEVEL=INFO

# Pierwsze uruchomienia tylko w dry-run.
DRY_RUN=true

STATE_DB_PATH=data/test-state.sqlite
AUDIT_LOG_PATH=logs/test-audit.jsonl
DRAFT_DIR=drafts/test-pending
WORKER_ID=mail-ai-test-worker-1
