IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASS=change-me
IMAP_TIMEOUT_SECONDS=30
IMAP_SEARCH_CRITERION=UNSEEN
IMAP_FETCH_LIMIT=100

IMAP_SOURCE_FOLDER=INBOX.AI-Review
IMAP_UNCERTAIN_FOLDER=INBOX.AI-Uncertain
IMAP_APPOINTMENTS_FOLDER=INBOX.Appointments
IMAP_QUESTIONS_FOLDER=INBOX.Questions
IMAP_COMPLAINTS_FOLDER=INBOX.Complaints
IMAP_SPAM_FOLDER=Junk
IMAP_NEWSLETTER_FOLDER=INBOX.Newsletter
IMAP_OFFER_FOLDER=INBOX.Offer
IMAP_OTHER_FOLDER=INBOX.Other
IMAP_BILLING_FOLDER=INBOX.Billing
IMAP_SYSTEM_FOLDER=INBOX.System

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_TEMPERATURE=0.1
OLLAMA_CIRCUIT_BREAKER_FAILURES=3
OLLAMA_CIRCUIT_BREAKER_TIMEOUT_SECONDS=300

MOVE_CONFIDENCE_THRESHOLD=0.75
OTHER_MOVE_CONFIDENCE_THRESHOLD=0.50
FLAG_CONFIDENCE_THRESHOLD=0.80
DRAFT_CONFIDENCE_THRESHOLD=0.85
PROCESSING_LEASE_SECONDS=900
MAX_BODY_CHARS=12000
MAX_RETRIES=3
LOG_LEVEL=INFO
DRY_RUN=true

STATE_DB_PATH=data/state.sqlite
AUDIT_LOG_PATH=logs/audit.jsonl
DRAFT_DIR=drafts/pending
WORKER_ID=mail-ai-worker-1
